# AI Provider Configuration
# Set one (or more) of these keys. The agent will auto-detect which provider to use.
# Priority: openai > anthropic > deepseek > gemini > ollama

# OpenAI (GPT-4o, GPT-4o-mini)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Claude Haiku)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek (cheapest option)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Google Gemini (free tier available)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama (local, no key needed)
# Install: https://ollama.com
# The agent auto-detects Ollama if it's running on localhost:11434
# Or specify: --provider ollama --base-url http://localhost:11434/v1
